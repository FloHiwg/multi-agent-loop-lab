{
  "$defs": {
    "DocumentFormat": {
      "enum": [
        "pdf",
        "xlsx"
      ],
      "title": "DocumentFormat",
      "type": "string"
    },
    "DocumentKind": {
      "enum": [
        "master",
        "vault"
      ],
      "title": "DocumentKind",
      "type": "string"
    },
    "DocumentRef": {
      "description": "One entry in an audit's document registry, pointing at a file on disk.",
      "properties": {
        "doc_id": {
          "title": "Doc Id",
          "type": "string"
        },
        "path": {
          "description": "Path relative to the repo root",
          "title": "Path",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/DocumentKind"
        },
        "format": {
          "$ref": "#/$defs/DocumentFormat"
        },
        "tag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Evidence class, e.g. 'finance_pack' -- matches evidence_priority",
          "title": "Tag"
        }
      },
      "required": [
        "doc_id",
        "path",
        "kind",
        "format"
      ],
      "title": "DocumentRef",
      "type": "object"
    },
    "ExactMatch": {
      "properties": {
        "kind": {
          "const": "exact",
          "default": "exact",
          "title": "Kind",
          "type": "string"
        }
      },
      "title": "ExactMatch",
      "type": "object"
    },
    "FormulaCheck": {
      "properties": {
        "kind": {
          "const": "formula",
          "default": "formula",
          "title": "Kind",
          "type": "string"
        },
        "formula": {
          "description": "Expression referencing other claim_ids, e.g. 'a + b - c'",
          "title": "Formula",
          "type": "string"
        },
        "tolerance_pct": {
          "default": 0.0,
          "maximum": 100,
          "minimum": 0,
          "title": "Tolerance Pct",
          "type": "number"
        }
      },
      "required": [
        "formula"
      ],
      "title": "FormulaCheck",
      "type": "object"
    },
    "PercentTolerance": {
      "properties": {
        "kind": {
          "const": "percent_tolerance",
          "default": "percent_tolerance",
          "title": "Kind",
          "type": "string"
        },
        "tolerance_pct": {
          "exclusiveMinimum": 0,
          "maximum": 100,
          "title": "Tolerance Pct",
          "type": "number"
        }
      },
      "required": [
        "tolerance_pct"
      ],
      "title": "PercentTolerance",
      "type": "object"
    }
  },
  "description": "audit.yaml -- the manifest for a single audit case.",
  "properties": {
    "audit_id": {
      "title": "Audit Id",
      "type": "string"
    },
    "master_doc_id": {
      "description": "doc_id of the master document under audits/<id>/master/",
      "title": "Master Doc Id",
      "type": "string"
    },
    "default_tolerance_rule": {
      "discriminator": {
        "mapping": {
          "exact": "#/$defs/ExactMatch",
          "formula": "#/$defs/FormulaCheck",
          "percent_tolerance": "#/$defs/PercentTolerance"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/ExactMatch"
        },
        {
          "$ref": "#/$defs/PercentTolerance"
        },
        {
          "$ref": "#/$defs/FormulaCheck"
        }
      ],
      "title": "Default Tolerance Rule"
    },
    "evidence_priority": {
      "description": "Ordered document classes/tags preferred as evidence when sources conflict",
      "items": {
        "type": "string"
      },
      "title": "Evidence Priority",
      "type": "array"
    },
    "documents": {
      "description": "Registry of master + vault documents this audit draws on",
      "items": {
        "$ref": "#/$defs/DocumentRef"
      },
      "title": "Documents",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    }
  },
  "required": [
    "audit_id",
    "master_doc_id",
    "created_at"
  ],
  "title": "AuditConfig",
  "type": "object"
}
