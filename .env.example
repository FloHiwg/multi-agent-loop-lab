# Copy this file to .env and fill in your key. .env is gitignored -- never commit it.

# Route the Claude Agent SDK through OpenRouter's Anthropic-compatible endpoint.
# See: https://openrouter.ai/docs/guides/community/anthropic-agent-sdk
OPENROUTER_API_KEY=

# Alternative: Z.ai's own Anthropic-compatible endpoint (typically cheaper
# for GLM models than the same model via OpenRouter). If both keys are set,
# OpenRouter wins unless PROOFBENCH_PROVIDER=zai is set.
# ZAI_API_KEY=
# PROOFBENCH_PROVIDER=zai

# Alternative: call Anthropic directly instead of via OpenRouter.
# If OPENROUTER_API_KEY is set above, it takes precedence and this is ignored.
# ANTHROPIC_API_KEY=
